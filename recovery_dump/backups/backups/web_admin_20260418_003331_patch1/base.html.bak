<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{{ page_title or "Greenhouse v17" }}</title>
  <link rel="stylesheet" href="/static/app.css" />
</head>
<body>
  <aside class="sidebar">
    <div class="brand">
      <div class="brand-title">GREENHOUSE v17</div>
      <div class="brand-subtitle">Web Admin</div>
    </div>

    <nav class="menu">
      <a href="/web/">🏠 Дашборд</a>
      <a href="/web/control">🎛 Control</a>
      <a href="/web/ask">❓ ASK</a>
      <a href="/web/modes">🧠 Режимы</a>
      <a href="/web/registry">🗂 Registry</a>
      <a href="/web/login">🔐 Логин</a>
    </nav>

    <div class="sidebar-box">
      <div class="sidebar-title">Интерфейсы</div>
      <div class="sidebar-note">
        Telegram + Web работают поверх одного v17 Core.
      </div>
    </div>
  </aside>

  <main class="main">
    <div class="topbar">
      <h1 class="page-title">{{ page_title or "Greenhouse v17" }}</h1>
      <button class="ghost-btn" onclick="logout()">Выйти</button>
    </div>

    {% block content %}{% endblock %}
  </main>

  <script>
    function logout() {
      localStorage.removeItem("gh_token");
      window.location.href = "/web/login";
    }
  </script>
  {% block scripts %}{% endblock %}
</body>
</html>
