{% extends "base.html" %}

{% block content %}
<div class="cards-grid">
  <section class="card">
    <div class="card-label">Система</div>
    <h3>Текущий режим</h3>
    <pre id="dash-mode" class="result-box">Загрузка...</pre>
  </section>

  <section class="card">
    <div class="card-label">Исполнение</div>
    <h3>Текущий ASK</h3>
    <pre id="dash-ask" class="result-box">Загрузка...</pre>
  </section>
</div>

<div class="cards-grid">
  <section class="card">
    <div class="card-label">Возможности</div>
    <h3>Что уже есть</h3>
    <ul class="clean-list">
      <li>ASK current / confirm / cancel</li>
      <li>Режимы системы</li>
      <li>Registry / actions / capabilities / scenarios</li>
      <li>Execution + verify через общий v17 pipeline</li>
      <li>Telegram и Web поверх одного контура</li>
      <li>Тестовое ручное управление вентиляторами</li>
    </ul>
  </section>

  <section class="card">
    <div class="card-label">Навигация</div>
    <h3>Быстрые действия</h3>
    <div class="button-row">
      <a class="ghost-btn-link" href="/web/control">Открыть Control</a>
      <a class="ghost-btn-link" href="/web/ask">Открыть ASK</a>
      <a class="ghost-btn-link" href="/web/modes">Режимы</a>
      <a class="ghost-btn-link" href="/web/registry">Registry</a>
    </div>
  </section>
</div>
{% endblock %}

{% block scripts %}
<script>
function authHeaders(withJson = false) {
  const token = localStorage.getItem("gh_token");
  if (!token) {
    window.location.href = "/web/login";
    throw new Error("not_authenticated");
  }
  const headers = { Authorization: "Bearer " + token };
  if (withJson) headers["Content-Type"] = "application/json";
  return headers;
}

async function loadDashboard() {
  const [modeResp, askResp] = await Promise.all([
    fetch("/api/modes/current", { headers: authHeaders(false) }),
    fetch("/api/ask/current", { headers: authHeaders(false) }),
  ]);

  const modeData = await modeResp.json();
  const askData = await askResp.json();

  document.getElementById("dash-mode").textContent = JSON.stringify(modeData, null, 2);
  document.getElementById("dash-ask").textContent = JSON.stringify(askData, null, 2);
}

loadDashboard();
</script>
{% endblock %}
