{% extends "base.html" %}

{% block content %}
<div class="cards-grid">
  <section class="card">
    <div class="card-label">ASK control</div>
    <h3>Подтверждение действий</h3>

    <div id="ask-summary" class="state-banner" style="display:none;"></div>

    <div id="ask-pending-card" class="pending-card" style="display:none;">
      <div class="pending-title" id="pending-title">Pending action</div>
      <div class="pending-meta" id="pending-meta">...</div>
      <div class="button-row">
        <button class="primary-btn" onclick="confirmAsk(true)">Подтвердить и выполнить</button>
        <button class="ghost-btn" onclick="confirmAsk(false)">Подтвердить без выполнения</button>
        <button class="danger-btn" onclick="cancelAsk()">Отменить</button>
      </div>
    </div>

    <div class="button-row">
      <button class="ghost-btn" onclick="loadAsk()">Обновить</button>
    </div>

    <pre id="ask-current" class="result-box">Загрузка...</pre>
    <pre id="ask-result" class="result-box" style="display:none;"></pre>
  </section>
</div>
{% endblock %}

{% block scripts %}
<script>
function authHeaders(withJson = true) {
  const token = localStorage.getItem("gh_token");
  if (!token) {
    window.location.href = "/web/login";
    throw new Error("not_authenticated");
  }
  const headers = { Authorization: "Bearer " + token };
  if (withJson) headers["Content-Type"] = "application/json";
  return headers;
}

function renderPendingCard(data) {
  const hasPending = !!(data && data.has_pending);
  const card = document.getElementById("ask-pending-card");
  const summary = document.getElementById("ask-summary");

  if (!hasPending) {
    card.style.display = "none";
    summary.style.display = "block";
    summary.className = "state-banner ok";
    summary.textContent = "Сейчас pending ASK нет.";
    return;
  }

  const item = data.item || {};
  document.getElementById("pending-title").textContent =
    item.title || item.action_key || "Pending ASK";

  document.getElementById("pending-meta").textContent =
    "action_key: " + (item.action_key || "—") +
    " | kind: " + (item.kind || "—") +
    " | created_at: " + (item.created_at || "—");

  summary.style.display = "block";
  summary.className = "state-banner warn";
  summary.textContent = "Есть действие, ожидающее подтверждения.";

  card.style.display = "block";
}

async function loadAsk() {
  const r = await fetch("/api/ask/current", { headers: authHeaders(false) });
  const data = await r.json();
  document.getElementById("ask-current").textContent = JSON.stringify(data, null, 2);
  renderPendingCard(data);
}

async function confirmAsk(execute) {
  const box = document.getElementById("ask-result");
  box.style.display = "block";
  box.textContent = "Обрабатываю подтверждение...";

  const r = await fetch("/api/ask/confirm", {
    method: "POST",
    headers: authHeaders(true),
    body: JSON.stringify({ execute })
  });

  const data = await r.json();
  box.textContent = JSON.stringify(data, null, 2);
  await loadAsk();
}

async function cancelAsk() {
  const box = document.getElementById("ask-result");
  box.style.display = "block";
  box.textContent = "Отменяю pending ASK...";

  const r = await fetch("/api/ask/cancel", {
    method: "POST",
    headers: authHeaders(true)
  });

  const data = await r.json();
  box.textContent = JSON.stringify(data, null, 2);
  await loadAsk();
}

loadAsk();
</script>
{% endblock %}
