{% extends "base.html" %}

{% block content %}
<section class="page-section" style="max-width:1120px;width:100%;margin:0 auto;">
  <div class="page-head">
    <div>
      <h1>AI Lab</h1>
      <p>TEST-страница AI Router / Context Builder / Chat Layer. Без прямого исполнения.</p>
    </div>
  </div>

  <div class="card" style="width:100%;box-sizing:border-box;">
    <textarea id="aiInput"
      style="width:100%;height:150px;resize:none;padding:18px;border-radius:18px;box-sizing:border-box;"
      placeholder="Например: включи верхний вентилятор"></textarea>

    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:14px;">
      <button onclick="sendAI()">Отправить</button>
      <button onclick="createAsk()" id="createAskBtn">Создать ASK</button>
    </div>
  </div>

  <div class="card" style="width:100%;box-sizing:border-box;min-height:520px;">
    <h2>Результат</h2>

    <div id="summaryBox" style="display:none;margin-bottom:16px;"></div>

    <pre id="aiOutput"
      style="white-space:pre-wrap;overflow:auto;height:360px;max-width:100%;margin:0;padding:16px;border-radius:16px;box-sizing:border-box;"></pre>
  </div>
</section>

<script>
function safe(v) {
  return (v === null || v === undefined || v === "") ? "—" : String(v);
}

function renderSummary(data) {
  const box = document.getElementById("summaryBox");
  const ai = data.ai_router || {};
  const intent = ai.parsed_intent || {};
  const ctx = ai.context || {};
  const mode = ctx.mode || {};
  const proposed = ai.proposed_action || null;
  const meta = ai.meta || {};

  box.style.display = "block";
  box.innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;">
      <div><b>Task</b><br>${safe(ai.task_type)}</div>
      <div><b>Intent</b><br>${safe(intent.intent_type)}</div>
      <div><b>Action</b><br>${safe(intent.action)}</div>
      <div><b>Target</b><br>${safe(intent.target)}</div>
      <div><b>Mode</b><br>${safe(mode.name)}</div>
      <div><b>Execution</b><br>${meta.execution_called ? "called" : "not called"}</div>
      <div><b>HA</b><br>${meta.ha_called ? "called" : "not called"}</div>
      <div><b>Proposal</b><br>${proposed ? "yes" : "no"}</div>
    </div>
  `;
}

async function sendAI() {
  const text = document.getElementById("aiInput").value;
  const out = document.getElementById("aiOutput");
  const box = document.getElementById("summaryBox");

  out.textContent = "Загрузка...";
  box.style.display = "none";

  const res = await fetch("/api/ai/message", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({text})
  });

  const data = await res.json();
  renderSummary(data);
  out.textContent = JSON.stringify(data, null, 2);
}

async function createAsk() {
  const text = document.getElementById("aiInput").value;
  const out = document.getElementById("aiOutput");

  if (!text.trim()) {
    alert("Сначала напиши команду");
    return;
  }

  out.textContent = "Создаю ASK...";

  const res = await fetch("/api/ai/create-ask", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({text})
  });

  const data = await res.json();

  if (data.ok) {
    out.textContent = JSON.stringify(data, null, 2);
    alert("ASK создан. Открой раздел ASK.");
  } else {
    out.textContent = JSON.stringify(data, null, 2);
    alert("ASK не создан: " + (data.error || "unknown_error"));
  }
}

</script>
{% endblock %}
