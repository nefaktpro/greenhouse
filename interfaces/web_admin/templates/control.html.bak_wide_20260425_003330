{% extends "base.html" %}
{% block content %}

<div class="control-page">
  <div class="control-left">
    <section class="control-panel">
      <div class="card-label">Control</div>
      <h2>Действия через общий pipeline</h2>
      <p class="muted control-desc">
        Все кнопки идут через action-based flow. Режимы TEST / ASK / MANUAL влияют на поведение.
      </p>

      <div class="control-tools">
        <button class="primary-btn" onclick="loadActions()">Обновить actions</button>
        <input id="action-search" type="text" placeholder="Поиск: action key, роль, операция..." oninput="renderActions()">
      </div>

      <div id="actions-box">Загрузка...</div>
    </section>
  </div>

  <aside class="control-right">
    <section class="control-result-card">
      <div class="card-label">Live result</div>
      <h3>Результат</h3>
      <pre id="action-result-box" class="result-box">Ожидание...</pre>
    </section>
  </aside>
</div>

{% endblock %}

{% block scripts %}
<script>
let ACTION_STATE = [];

function esc(text) {
  return String(text ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;");
}


function entriesFromActionMap(payload) {
  const data = payload?.data ?? payload ?? {};
  const real = data.items || data.actions || data.debug?.items || data.debug?.actions || data.debug || data;

  let arr = [];
  if (Array.isArray(real)) {
    arr = real;
  } else if (real && typeof real === "object") {
    arr = Object.entries(real).map(([action_key, value]) => ({
      action_key,
      ...(value || {})
    }));
  }

  return arr.filter(x => {
    const k = String(x.action_key || "");
    return k.includes("_") && !["ok", "count", "items"].includes(k);
  });
}

function humanName(key, item) {
  const role = String(item.target_role || item.logical_role || item.role || "");
  const base = String(key || "")
    .replace(/_on$/, "")
    .replace(/_off$/, "");

  const names = {
    fan_top: "Вентиляторы верх",
    fan_bottom: "Вентиляторы низ",
    fan_low: "Вентиляторы низ",
    humidifier: "Увлажнитель",
    humidifier_power: "Питание увлажнителя",
    curtain: "Штора",
    light_top: "Свет верх",
    light_bottom: "Свет низ",
    watering_top: "Полив верх",
    watering_bottom: "Полив низ",
    veranda_main_power: "Щиток веранда"
  };

  if (role === "top_air_circulation") return "Вентиляторы верх";
  if (role === "bottom_air_circulation") return "Вентиляторы низ";
  return names[base] || item.title || base || key;
}

function groupActions(items) {
  const groups = {};
  for (const item of items) {
    const key = String(item.action_key || "");
    const base = key.replace(/_on$/, "").replace(/_off$/, "");
    if (!groups[base]) {
      groups[base] = {
        base,
        title: humanName(key, item),
        on: null,
        off: null,
        sample: item
      };
    }
    if (key.endsWith("_on")) groups[base].on = item;
    else if (key.endsWith("_off")) groups[base].off = item;
    else groups[base].single = item;
  }
  return Object.values(groups);
}

function renderActions() {
  const q = (document.getElementById("action-search")?.value || "").trim().toLowerCase();
  const box = document.getElementById("actions-box");

  const groups = groupActions(ACTION_STATE).filter(g => {
    const blob = [
      g.title,
      g.base,
      g.on?.action_key,
      g.off?.action_key,
      g.sample?.target_role,
      g.sample?.logical_role,
      g.sample?.operation
    ].map(v => String(v || "").toLowerCase()).join(" | ");
    return !q || blob.includes(q);
  });

  if (!groups.length) {
    box.innerHTML = `<div class="control-empty">Действия не найдены</div>`;
    return;
  }

  box.innerHTML = `
    <div class="control-action-list">
      ${groups.map(g => `
        <article class="control-action-row">
          <div>
            <div class="control-action-kicker">УСТРОЙСТВО</div>
            <div class="control-action-title">${esc(g.title)}</div>
          </div>

          <div class="control-action-meta">
            <div><span>role:</span> ${esc(g.sample?.target_role || g.sample?.logical_role || "—")}</div>
            <div><span>on:</span> ${esc(g.on?.action_key || "—")}</div>
            <div><span>off:</span> ${esc(g.off?.action_key || "—")}</div>
          </div>

          <div class="control-action-desc">
            ${esc(g.sample?.description || "Через общий execution/ASK pipeline.")}
          </div>

          <div style="display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;">
            ${g.on ? `<button class="primary-btn control-run-btn" onclick='runAction(${JSON.stringify(g.on.action_key)})'>Включить</button>` : ""}
            ${g.off ? `<button class="ghost-btn control-run-btn" onclick='runAction(${JSON.stringify(g.off.action_key)})'>Выключить</button>` : ""}
            ${!g.on && !g.off && g.single ? `<button class="primary-btn control-run-btn" onclick='runAction(${JSON.stringify(g.single.action_key)})'>Выполнить</button>` : ""}
          </div>
        </article>
      `).join("")}
    </div>
  `;
}

async function loadActions() {
  if (!requireAuth()) return;

  const result = await ghTryGetVariants([
    "/api/registry/actions",
    "/api/registry/action_map"
  ]);

  if (!result.ok) {
    pretty("action-result-box", result);
    return;
  }

  ACTION_STATE = entriesFromActionMap(result.data);
  renderActions();
}

async function runAction(actionKey) {
  if (!requireAuth()) return;

  document.getElementById("action-result-box").textContent = "Выполняю действие через pipeline...";

  const result = await ghTryPostVariants([
    { url: "/api/actions/execute", body: { action_key: actionKey } },
    { url: "/api/actions/run", body: { action_key: actionKey } },
    { url: "/api/actions/execute", body: { key: actionKey } }
  ]);

  pretty("action-result-box", result);
}

loadActions();
</script>
{% endblock %}
