{% extends "base.html" %}
{% block content %}
<style>
.ask-page{max-width:1120px;margin:0 auto}
.ask-hero{margin-bottom:18px}
.ask-hero h1{font-size:42px;margin:0 0 10px}
.ask-hero p{color:#c7d5ee;margin:0;font-size:18px}
.ask-shell{display:grid;grid-template-columns:1fr 360px;gap:18px;align-items:start}
.ask-card{background:rgba(7,16,34,.92);border:1px solid rgba(71,115,190,.42);border-radius:26px;padding:28px}
.ask-badge{display:inline-flex;border-radius:999px;padding:10px 16px;font-weight:900;margin-bottom:18px}
.ask-badge.empty{background:rgba(126,231,135,.12);color:#7ee787;border:1px solid rgba(126,231,135,.32)}
.ask-badge.pending{background:rgba(255,216,102,.13);color:#ffd866;border:1px solid rgba(255,216,102,.36)}
.ask-badge.work{background:rgba(88,166,255,.13);color:#8fb3ff;border:1px solid rgba(88,166,255,.36)}
.ask-title{font-size:34px;line-height:1.1;font-weight:950;margin:0 0 18px;color:#fff}
.ask-human{background:rgba(14,30,62,.75);border:1px solid rgba(71,115,190,.32);border-radius:22px;padding:22px;margin:18px 0}
.ask-human h2{margin:0 0 10px;font-size:22px}
.ask-human .big{font-size:26px;font-weight:950;color:#fff;margin-top:4px}
.ask-info{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-top:18px}
.ask-field{background:rgba(9,20,44,.72);border:1px solid rgba(71,115,190,.24);border-radius:16px;padding:14px}
.ask-field b{display:block;color:#8fb3ff;font-size:12px;text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px}
.ask-field span{color:#eef5ff;word-break:break-word}
.ask-buttons{display:grid;grid-template-columns:1.4fr 1fr 1fr;gap:12px;margin-top:22px}
.ask-buttons button{font-size:17px;padding:15px 18px;border-radius:16px}
.ask-confirm{background:linear-gradient(135deg,#4f8cff,#2f6df6)!important;color:white!important}
.ask-cancel{background:rgba(255,92,122,.12)!important;border:1px solid rgba(255,92,122,.32)!important;color:#ffc2cd!important}
.ask-status-card{position:sticky;top:20px}
.status-line{background:rgba(14,30,62,.70);border:1px solid rgba(71,115,190,.28);border-radius:18px;padding:16px;margin-top:12px}
.status-line b{display:block;color:#8fb3ff;margin-bottom:6px}
.status-line span{color:#eef5ff}
.ask-debug{margin-top:14px}
.ask-debug summary{cursor:pointer;color:#8fb3ff;font-weight:800}
.ask-debug pre{height:220px;overflow:auto;margin-top:10px}
@media(max-width:1000px){.ask-shell{grid-template-columns:1fr}.ask-buttons{grid-template-columns:1fr}.ask-info{grid-template-columns:1fr}.ask-status-card{position:static}}
</style>

<section class="ask-page">
  <div class="ask-hero">
    <h1>ASK</h1>
    <p>Подтверждение действий перед исполнением через Core / Validation / Execution.</p>
  </div>

  <div class="ask-shell">
    <article class="ask-card">
      <div id="ask-badge" class="ask-badge empty">Загрузка...</div>
      <div id="ask-title" class="ask-title">Проверяю pending-действия...</div>

      <div id="ask-human" class="ask-human">
        <h2>Что будет сделано</h2>
        <div id="ask-human-text" class="big">—</div>
      </div>

      <div id="ask-info" class="ask-info"></div>

      <div class="ask-buttons">
        <button id="ask-confirm-btn" class="ask-confirm" onclick="confirmAsk()" disabled>✅ Подтвердить и выполнить</button>
        <button id="ask-cancel-btn" class="ask-cancel" onclick="cancelAsk()" disabled>❌ Отменить</button>
        <button onclick="loadAsk()">🔄 Обновить</button>
      </div>
    </article>

    <aside class="ask-card ask-status-card">
      <h2>Онлайн-статус</h2>
      <div class="status-line"><b>Состояние</b><span id="live-state">Загрузка...</span></div>
      <div class="status-line"><b>Последнее действие</b><span id="live-action">—</span></div>
      <div class="status-line"><b>Результат</b><span id="live-result">—</span></div>

      <details class="ask-debug">
        <summary>Debug JSON</summary>
        <pre id="ask-result-box" class="result-box">{}</pre>
      </details>
    </aside>
  </div>
</section>
{% endblock %}

{% block scripts %}
<script>
function esc(v){return String(v ?? "—").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;")}
function field(label,value){return `<div class="ask-field"><b>${esc(label)}</b><span>${esc(value)}</span></div>`}

function humanAction(item){
  const op = item.operation === "turn_on" ? "Включить" : item.operation === "turn_off" ? "Выключить" : (item.operation || "Выполнить");
  const key = item.action_key || "";
  if(key.includes("fan_top")) return `${op} верхний вентилятор`;
  if(key.includes("fan_low")) return `${op} нижний вентилятор`;
  return `${op}: ${item.title || item.action_key || "действие"}`;
}

function setLive(state, action, result){
  document.getElementById("live-state").textContent = state || "—";
  document.getElementById("live-action").textContent = action || "—";
  document.getElementById("live-result").textContent = result || "—";
}

function renderEmpty(data){
  document.getElementById("ask-badge").className="ask-badge empty";
  document.getElementById("ask-badge").textContent="Нет pending ASK";
  document.getElementById("ask-title").textContent="Сейчас нет действий, ожидающих подтверждения";
  document.getElementById("ask-human-text").textContent="Ничего не ожидает подтверждения";
  document.getElementById("ask-info").innerHTML="";
  document.getElementById("ask-confirm-btn").disabled=true;
  document.getElementById("ask-cancel-btn").disabled=true;
  setLive("Ожидание", "Нет pending-действий", "—");
  pretty("ask-result-box", data);
}

function renderPending(item,data){
  document.getElementById("ask-badge").className="ask-badge pending";
  document.getElementById("ask-badge").textContent="Ожидает подтверждения";
  document.getElementById("ask-title").textContent=item.title || item.action_key || "Ожидает подтверждения";
  document.getElementById("ask-human-text").textContent=humanAction(item);

  document.getElementById("ask-info").innerHTML=[
    field("Action key", item.action_key),
    field("Устройство", item.entity_id),
    field("Операция", item.operation),
    field("Источник", item.source),
    field("Тип", item.kind),
    field("Создано", item.created_at)
  ].join("");

  document.getElementById("ask-confirm-btn").disabled=false;
  document.getElementById("ask-cancel-btn").disabled=false;
  setLive("Ждёт решения", humanAction(item), "Нужно подтвердить или отменить");
  pretty("ask-result-box", data);
}

async function loadAsk(){
  const res = await fetch("/api/ask/current");
  const data = await res.json();
  if(!data.ok){ pretty("ask-result-box", data); setLive("Ошибка", "Загрузка ASK", data.error || "unknown"); return; }
  if(data.has_pending){ renderPending(data.item || {}, data); }
  else { renderEmpty(data); }
}

async function confirmAsk(){
  document.getElementById("ask-badge").className="ask-badge work";
  document.getElementById("ask-badge").textContent="Выполняю...";
  setLive("Выполнение", "Подтверждение ASK", "Команда отправлена в execution");

  const res = await fetch("/api/ask/confirm", {method:"POST"});
  const data = await res.json();
  pretty("ask-result-box", data);
  setLive(data.ok ? "Готово" : "Ошибка", "Confirm", data.ok ? "Действие обработано" : (data.error || "Ошибка"));
  setTimeout(loadAsk, 900);
}

async function cancelAsk(){
  setLive("Отмена", "Cancel ASK", "Отправляю отмену");
  const res = await fetch("/api/ask/cancel", {method:"POST"});
  const data = await res.json();
  pretty("ask-result-box", data);
  setLive(data.ok ? "Отменено" : "Ошибка", "Cancel", data.ok ? "Pending снят" : (data.error || "Ошибка"));
  setTimeout(loadAsk, 700);
}

document.addEventListener("DOMContentLoaded", () => {
  loadAsk();
  setInterval(loadAsk, 5000);
});
</script>
{% endblock %}
