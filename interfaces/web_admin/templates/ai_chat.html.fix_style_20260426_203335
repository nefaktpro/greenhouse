<script>
(function(){
  function esc(s){
    return String(s || "")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;");
  }

  function findChatBox(){
    const candidates = [
      "#chatMessages",
      "#messages",
      "#chatBox",
      ".chat-messages",
      ".messages",
      "[data-chat-messages]"
    ];

    for (const sel of candidates){
      const el = document.querySelector(sel);
      if (el) return el;
    }

    const all = Array.from(document.querySelectorAll("div"));
    return all.find(el => {
      const st = getComputedStyle(el);
      return el.clientHeight > 250 && (st.overflowY === "auto" || st.overflowY === "scroll");
    });
  }

  async function forceRenderAiHistory(){
    const box = findChatBox();
    if (!box) {
      console.log("AI history: chat box not found");
      return;
    }

    const r = await fetch("/api/ai/chat-history?ts=" + Date.now(), {cache:"no-store"});
    const data = await r.json();
    const history = data.history || [];

    console.log("AI history loaded:", history.length, "box:", box);

    box.innerHTML = "";

    history.slice(-40).forEach(m => {
      const role = m.role === "user" ? "user" : "ai";
      const div = document.createElement("div");
      div.className = "msg " + role;
      div.style.whiteSpace = "pre-wrap";
      div.style.margin = "10px 0";
      div.style.padding = "12px 14px";
      div.style.borderRadius = "14px";
      div.style.background = role === "user" ? "rgba(143,179,255,.16)" : "rgba(255,184,107,.12)";
      div.style.border = "1px solid rgba(255,255,255,.10)";
      div.innerHTML = esc(m.content || "");
      box.appendChild(div);
    });

    box.scrollTop = box.scrollHeight;
  }

  window.forceRenderAiHistory = forceRenderAiHistory;

  document.addEventListener("DOMContentLoaded", () => {
    setTimeout(forceRenderAiHistory, 500);
    setTimeout(forceRenderAiHistory, 1500);
    setTimeout(forceRenderAiHistory, 3000);
  });

  window.addEventListener("load", () => {
    setTimeout(forceRenderAiHistory, 500);
    setTimeout(forceRenderAiHistory, 1500);
  });
})();
</script>


<script>
(function(){
  async function loadAiChatHistoryOnOpen(){
    try{
      const r = await fetch("/api/ai/chat-history?ts=" + Date.now(), {cache:"no-store"});
      const data = await r.json();
      const history = data.history || [];
      if(!history.length) return;

      if(typeof renderHistory === "function"){
        renderHistory(history);
        return;
      }

      if(typeof addMsg === "function"){
        const box = document.querySelector("#chatMessages,#messages,#chatBox,.chat-messages,.messages");
        if(box) box.innerHTML = "";
        history.slice(-60).forEach(m => addMsg(m.role === "user" ? "user" : "ai", m.content || ""));
      }
    }catch(e){
      console.log("loadAiChatHistoryOnOpen failed", e);
    }
  }

  window.addEventListener("load", function(){
    setTimeout(loadAiChatHistoryOnOpen, 200);
    setTimeout(loadAiChatHistoryOnOpen, 900);
  });
})();
</script>
