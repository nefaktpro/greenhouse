{% extends "base.html" %}

{% block content %}
<section class="page-section">
  <div class="page-head">
    <div>
      <h1>AI Lab</h1>
      <p>TEST-страница AI Router / Context Builder / Chat Layer. Без прямого исполнения.</p>
    </div>
  </div>

  <div class="card">
    <textarea id="aiInput" style="width:100%;min-height:110px;padding:12px;border-radius:14px;" placeholder="Например: включи верхний вентилятор"></textarea>
<button onclick="createAsk()" style="margin-top:10px;">Создать ASK</button>
    <button onclick="sendAI()" style="margin-top:12px;">Отправить</button>
  </div>

  <div class="card">
    <h2>Результат</h2>
    <pre id="aiOutput" style="white-space:pre-wrap;overflow:auto;max-height:70vh;"></pre>
  </div>
</section>

<script>
async function sendAI() {
  const text = document.getElementById("aiInput").value;
  const out = document.getElementById("aiOutput");
  out.textContent = "Загрузка...";

  const res = await fetch("/api/ai/message", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({text})
  });

  const data = await res.json();
  out.textContent = JSON.stringify(data, null, 2);
}
</script>
{% endblock %}


<script>
async function createAsk() {
  const text = document.getElementById("aiInput").value;

  const res = await fetch("/api/ai/create-ask", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({text})
  });

  const data = await res.json();
  alert(JSON.stringify(data, null, 2));
}
</script>
