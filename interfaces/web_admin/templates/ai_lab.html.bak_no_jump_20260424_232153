{% extends "base.html" %}

{% block content %}
<section class="page-section">
  <div class="page-head">
    <div>
      <h1>AI Lab</h1>
      <p>TEST-страница AI Router / Context Builder / Chat Layer. Без прямого исполнения.</p>
    </div>
  </div>

  <div class="card" style="max-width:980px;">
    <textarea id="aiInput"
      style="width:100%;height:150px;resize:vertical;padding:18px;border-radius:18px;box-sizing:border-box;"
      placeholder="Например: включи верхний вентилятор"></textarea>

    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-top:14px;">
      <button onclick="sendAI()">Отправить</button>
    </div>
  </div>

  <div class="card" style="max-width:980px;">
    <h2>Результат</h2>

    <div id="summaryBox" style="display:none;margin-bottom:16px;"></div>

    <pre id="aiOutput"
      style="white-space:pre-wrap;overflow:auto;height:420px;margin:0;padding:16px;border-radius:16px;box-sizing:border-box;"></pre>
  </div>
</section>

<script>
function renderSummary(data) {
  const box = document.getElementById("summaryBox");
  const ai = data.ai_router || {};
  const intent = ai.parsed_intent || {};
  const ctx = ai.context || {};
  const mode = ctx.mode || {};
  const proposed = ai.proposed_action || null;
  const meta = ai.meta || {};

  box.style.display = "block";
  box.innerHTML = `
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;">
      <div><b>Task</b><br>${ai.task_type || "—"}</div>
      <div><b>Intent</b><br>${intent.intent_type || "—"}</div>
      <div><b>Action</b><br>${intent.action || "—"}</div>
      <div><b>Target</b><br>${intent.target || "—"}</div>
      <div><b>Mode</b><br>${mode.name || "—"}</div>
      <div><b>Execution</b><br>${meta.execution_called ? "called" : "not called"}</div>
      <div><b>HA</b><br>${meta.ha_called ? "called" : "not called"}</div>
      <div><b>Proposal</b><br>${proposed ? "yes" : "no"}</div>
    </div>
  `;
}

async function sendAI() {
  const text = document.getElementById("aiInput").value;
  const out = document.getElementById("aiOutput");
  const box = document.getElementById("summaryBox");

  out.textContent = "Загрузка...";
  box.style.display = "none";

  const res = await fetch("/api/ai/message", {
    method: "POST",
    headers: {"Content-Type": "application/json"},
    body: JSON.stringify({text})
  });

  const data = await res.json();
  renderSummary(data);
  out.textContent = JSON.stringify(data, null, 2);
}
</script>
{% endblock %}
